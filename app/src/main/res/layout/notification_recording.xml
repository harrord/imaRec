<?xml version="1.0" encoding="utf-8"?>
<!--
    录音中/暂停态的自定义通知布局（锁屏卡片）。
    从左到右三部分：
      1. 声波 ImageView —— 由 Service 定时生成 Bitmap 刷新（60ms/帧），不重建整个通知
      2. 分段 Button —— 实心填充，72x36dp，13sp 字，录音态绿色/暂停态灰色
      3. 暂停/继续 Button —— 实心填充，72x36dp，13sp 字，录音态绿色(暂停)/暂停态琥珀色(继续)

    按钮尺寸严格固定，文字居中，避免文字溢出圆角框。
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="12dp"
    android:paddingEnd="12dp"
    android:paddingTop="10dp"
    android:paddingBottom="10dp">

    <!-- 第 1 部分：声波 -->
    <ImageView
        android:id="@+id/wave_image"
        android:layout_width="0dp"
        android:layout_height="40dp"
        android:layout_weight="1"
        android:scaleType="fitCenter"
        android:contentDescription="声波" />

    <!-- 第 2 部分：分段按钮 -->
    <Button
        android:id="@+id/segment_button"
        android:layout_width="72dp"
        android:layout_height="36dp"
        android:layout_marginStart="12dp"
        android:minWidth="0dp"
        android:minHeight="0dp"
        android:padding="0dp"
        android:text="分段"
        android:textSize="13sp"
        android:textStyle="bold"
        android:textColor="#FFFFFFFF"
        android:gravity="center"
        android:background="@drawable/btn_segment_recording" />

    <!-- 第 3 部分：暂停/继续按钮 -->
    <Button
        android:id="@+id/toggle_button"
        android:layout_width="72dp"
        android:layout_height="36dp"
        android:layout_marginStart="8dp"
        android:minWidth="0dp"
        android:minHeight="0dp"
        android:padding="0dp"
        android:text="暂停"
        android:textSize="13sp"
        android:textStyle="bold"
        android:textColor="#FFFFFFFF"
        android:gravity="center"
        android:background="@drawable/btn_toggle_recording" />
</LinearLayout>
