<?xml version="1.0" encoding="utf-8"?>
<!--
    录音中/暂停态的自定义通知布局（锁屏卡片）。
    从左到右三部分，三个按钮通过 layout_weight=1 等分占满卡片内宽，
    左右各距卡片边缘 12dp（由外层 padding 决定），按钮间 8dp 间距：
      1. 分组 Button —— 切换知识库并触发 5 秒后台倒计时后分段
      2. 分段 Button —— 实心填充，36dp 高，13sp 字，录音态绿色/暂停态灰色
      3. 暂停/继续 Button —— 实心填充，36dp 高，13sp 字，录音态绿色(暂停)/暂停态琥珀色(继续)

    状态文案仅在状态切换时更新，不周期性 notify()，避免按钮点击事件被 View 重建吞掉。
    文字居中，避免文字溢出圆角框。
    分组反馈行（feedback_text）默认隐藏，点击分组/分段按钮后显示，5 秒后由后台倒计时清除。
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="12dp"
    android:paddingEnd="12dp"
    android:paddingTop="2dp"
    android:paddingBottom="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- 第 1 部分：分组按钮 -->
        <Button
            android:id="@+id/group_button"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:padding="0dp"
            android:text="分组"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#FFFFFFFF"
            android:gravity="center"
            android:background="@drawable/btn_segment_recording" />

        <!-- 第 2 部分：分段按钮 -->
        <Button
            android:id="@+id/segment_button"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:padding="0dp"
            android:text="分段"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#FFFFFFFF"
            android:gravity="center"
            android:background="@drawable/btn_segment_recording" />

        <!-- 第 3 部分：暂停/继续按钮 -->
        <Button
            android:id="@+id/toggle_button"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:padding="0dp"
            android:text="暂停"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#FFFFFFFF"
            android:gravity="center"
            android:background="@drawable/btn_toggle_recording" />
    </LinearLayout>

    <!-- 提示行：始终可见，固定 16dp 高度保证卡片高度恒定。
         默认文案随录音状态切换（录音中/已暂停），点击分组/分段按钮后临时显示反馈，
         倒计时结束后恢复默认文案。单行居中，超长省略。
         文字颜色由代码根据系统深色/浅色模式动态设置，保证可识别性。 -->
    <TextView
        android:id="@+id/feedback_text"
        android:layout_width="match_parent"
        android:layout_height="16dp"
        android:layout_marginTop="4dp"
        android:textSize="12sp"
        android:gravity="center"
        android:maxLines="1"
        android:ellipsize="end"
        android:visibility="visible"
        android:text="人生记录中..." />
</LinearLayout>
